			{
				"name": "DoRunShortcut",
				"description": "Run a Windows desktop shortcut (.lnk) by name or full path. Windows only.\r\nIf a plain name is given (no path separators, no .lnk extension),\r\nit is resolved from the user's Desktop or the Public Desktop folder.\r\n@param {string} desktopShortcutNameOrShortcutPath Shortcut name (e.g. \"MyApp\") or full path to a .lnk file\r\n@returns {number} Exit code or PID depending on the shortcut target\r\n",
				"type": "number",
				"returns": "Exit code of the launched shortcut.",
				"signature": "/**string*/desktopShortcutNameOrShortcutPath",
				"paramInfo": {
					"desktopShortcutNameOrShortcutPath": {
						"description": "Shortcut name (e.g. 'MyApp') or full path to a .lnk file.",
						"binding": "path",
						"ext": "lnk"
					}
				},
				"src": "%WORKDIR%PageObjects\\CmdHelper\\CmdHelper.js(609,10)"
			},
			{
				"name": "DoRunStoreApp",
				"description": "Launch a Windows Store (UWP/MSIX) app by package family name or by matching a name/substring.\r\nWindows only. Uses the COM IApplicationActivationManager API to launch the app and capture its PID.\r\nIf the name contains '!' or '_' it is treated as a package family name and launched directly.\r\nOtherwise, installed packages are searched for a match and the first hit is launched.\r\n@param {string} name Package family name (e.g. \"Microsoft.WindowsCalculator_8wekyb3d8bbwe!App\") or a display name / substring to match (e.g. \"Calculator\")\r\n@returns {number} PID of the launched app, or -1 on failure\r\n",
				"type": "number",
				"returns": "PID of the launched app, or -1 on failure.",
				"signature": "/**string*/name",
				"paramInfo": {
					"name": {
						"description": "Package family name (e.g. 'Microsoft.WindowsCalculator_8wekyb3d8bbwe!App') or a display name / substring to match (e.g. 'Calculator')."
					}
				},
				"src": "%WORKDIR%PageObjects\\CmdHelper\\CmdHelper.js(708,10)"
			},
			{
				"name": "Pipe",
				"description": "Add a command to the pipe stack. Commands in the stack are chained\r\ntogether when DoCmd is called: stdout of each feeds stdin of the next.\r\n@param {string} cmd Command to add\r\n@param {string|boolean} stdoutFile Path for stdout, or false to skip collection for this step\r\n@param {string} stderrFile Path for stderr\r\n",
				"type": "",
				"returns": "",
				"signature": " /**string*/ cmd, /**string|boolean*/ stdoutFile, /**string*/ stderrFile",
				"paramInfo": {
					"cmd": {
						"description": "Command to add to the pipe chain."
					},
					"stdoutFile": {
						"description": "Path to write stdout to, or `false` to skip collection for this step.",
						"binding": "path",
						"ext": "txt",
						"optional": true,
