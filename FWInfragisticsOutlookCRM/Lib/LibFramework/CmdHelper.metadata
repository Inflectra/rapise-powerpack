{
	"CmdHelper": {
		"window_name": "PageObjects",
		"flavor": "GlobalObject",
		"actions": [
			{
				"name": "DoCmd",
				"description": "Execute a command or a chain of piped commands.\r\nSignatures:\r\nDoCmd(cmd, stdoutFile, stderrFile) - run cmd, write stdout/stderr to user files\r\nDoCmd(cmd)                         - run cmd, collect output internally\r\nDoCmd(cmd, false)                  - run cmd, skip output collection\r\nDoCmd()                            - execute pipe stack only\r\nDoCmd(cmd)                         - execute pipe stack + cmd as final step\r\nWhen only one file path is given as stdoutFile (and stderrFile is undefined),\r\nboth stdout and stderr go to that single file.\r\n@param {string} cmd Command to run (optional if pipe stack has entries)\r\n@param {string|boolean} stdoutFile Path for stdout, or false to skip collection\r\n@param {string} stderrFile Path for stderr\r\n@returns {number} Exit code of the last command\r\n",
				"type": "number",
				"returns": "Exit code of the last command in the chain.",
				"signature": " /**string*/ cmd, /**string|boolean*/ stdoutFile, /**string*/ stderrFile",
				"paramInfo": {
					"cmd": {
						"description": "Command to execute. Optional if pipe stack has entries.",
						"defaultValue": ""
					},
					"stdoutFile": {
						"description": "Path to write stdout to, or `false` to skip output collection.",
						"binding": "path",
						"ext": "txt",
						"optional": true,
						"defaultValue": ""
					},
					"stderrFile": {
						"description": "Path to write stderr to.",
						"binding": "path",
						"ext": "txt",
						"optional": true,
						"defaultValue": ""
					}
				},
				"src": "%WORKDIR%PageObjects\\CmdHelper\\CmdHelper.js(396,10)"
			},
