			{
				"name": "VerifySuccess",
				"description": "Verify that the last command exited with code 0 and produced no stderr output.\r\n@param {string} message Assertion message\r\n",
				"type": "",
				"returns": "",
				"signature": "/**string*/message",
				"paramInfo": {
